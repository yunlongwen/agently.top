# AI 后端专项信息源 Spider 环境变量配置
#
# 使用方法：
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入实际值
#   3. 启动脚本会自动 source 此文件，也可以手动 source .env
#
# 注意：.env 文件已在 .gitignore 中，不会被提交到版本控制

# GitHub Personal Access Token (需要 models:read 权限)
export GITHUB_TOKEN=""

# 163 邮箱 SMTP 配置
export SMTP_USER="changwenbo141@163.com"
export SMTP_PASSWORD=""
export MAIL_TO="727987105@qq.com,wenbo.chang@huolala.cn"
# 可选：按调度时间指定不同收件人；配置后优先于 MAIL_TO / EMAIL_SEND_TIMES
# export MAIL_TO_BY_TIME='{"07:50":"a@example.com,b@example.com","15:50":"c@example.com","23:50":"d@example.com"}'

# 邮件默认不发送；开启后按 EMAIL_SEND_TIMES 或 MAIL_TO_BY_TIME 发送
export SEND_EMAIL_ENABLED=false
# 未配置 MAIL_TO_BY_TIME 时，仅在这些调度时间发送邮件；采集仍按 SPIDER_SCHEDULE_TIMES 执行
export EMAIL_SEND_TIMES="07:50"

# =========================================================================
# 多平台发布配置（微信公众号等）
# =========================================================================

# 是否启用自动发布编排。关闭后采集完成不会触发任何发布器。
export PUBLISH_ENABLED=false

# 允许执行发布的每日调度时间，24 小时制，逗号分隔。为空则跟随 SPIDER_SCHEDULE_TIMES。
# export PUBLISH_SCHEDULE_TIMES="07:50"

# 管理员 API Token，用于 /api/admin/publish/* 等管理接口鉴权。
# export ADMIN_API_TOKEN="your-secure-token"

# 微信公众号发布配置
export WECHAT_PUBLISH_ENABLED=false
export WECHAT_APP_ID=""
export WECHAT_APP_SECRET=""

# 默认标题、作者、摘要。标题中 {date} 会被替换为当前日期。
# export WECHAT_DEFAULT_TITLE="Agently.top 每日 AI 资讯 - {date}"
# export WECHAT_DEFAULT_AUTHOR="Agently"
# export WECHAT_DEFAULT_DIGEST=""

# 封面图兜底 URL（正文无图时使用）
# export WECHAT_FALLBACK_LOGO_URL="https://agently.top/android-chrome-192x192.png"

# 文末「阅读原文」跳转 URL。未配置时自动使用当日第一条资讯的 url。
# export WECHAT_CONTENT_SOURCE_URL="https://agently.top/"

# 当正文无图时，是否调用 LLM 生成封面（默认 false）
# export WECHAT_GENERATE_COVER_BY_LLM=true

# LLM 封面设计提示词模板（可选）
# export WECHAT_COVER_PROMPT_TEMPLATE="..."

# 图片生成 API 配置（可选）。如果你的 LLM 接口支持图片生成，可配置此项。
# export IMAGE_GEN_API_URL="https://api.openai.com/v1"
# export IMAGE_GEN_API_KEY=""
# export IMAGE_GEN_MODEL="dall-e-3"
# export IMAGE_GEN_SIZE="1024x1024"

# Pillow 文字封面尺寸
# export COVER_IMAGE_WIDTH="900"
# export COVER_IMAGE_HEIGHT="500"

# 正文最大字符数限制
# export WECHAT_CONTENT_MAX_LENGTH="15000"

# =========================================================================
# 分层记忆系统配置
# =========================================================================

# 是否启用分层记忆系统。关闭后每日生成不读取/写入记忆。
export MEMORY_ENABLED=true

# 每日趋势记忆（L1）保留天数。
# export MEMORY_DAILY_TTL_DAYS=7

# 主题追踪记忆（L2）保留天数。
# export MEMORY_TOPIC_TTL_DAYS=30

# 编辑决策记忆（L3）保留天数。
# export MEMORY_EDITORIAL_TTL_DAYS=14

# 注入摘要 prompt 的历史上下文最大主题数。
# export MEMORY_CONTEXT_MAX_TOPICS=5

# 是否使用 LLM 做主题匹配（true 更准但增加调用成本）。
# export MEMORY_LLM_ENABLED=false

# 发布来源白名单（逗号分隔 source id），为空表示所有来源
# export WECHAT_SOURCE_WHITELIST="github-daily,hacker-news,openai,anthropic"

# 每个来源最多取 N 条用于发布
# export WECHAT_MAX_ITEMS_PER_SOURCE="5"

# Redis / API 配置
export REDIS_URL="redis://localhost:6379/0"
export REDIS_SNAPSHOT_TTL_SECONDS=259200
export REDIS_KEY_PREFIX="github-trending-spider"
export API_MAX_ITEMS_PER_SOURCE=100

# 内置采集调度：启动 API 后由 Python 进程自动按时间采集
export SPIDER_SCHEDULER_ENABLED=true
export SPIDER_SCHEDULE_TIMES="07:50,15:50,23:50"
export SPIDER_RUN_ON_STARTUP=false

# 本地启动脚本可覆盖端口
# export BACKEND_HOST="0.0.0.0"
# export BACKEND_PORT=8000
# export FRONTEND_HOST="127.0.0.1"
# export FRONTEND_PORT=8080

# 数量配置（均有默认值，可选配置）
# 如果配置数量大于实际可抓取数量，则只展示实际抓到的数量
# export GITHUB_TRENDING_TOP_COUNT=10  # GitHub Daily/Weekly 各获取前 N 个仓库，默认 10
# export HN_TOP_COUNT=10               # HN 获取前 N 个热门帖子，默认 10
# export HN_COMMENTS_PER_STORY=10      # 每帖获取前 N 条评论，默认 10
# export SSPAI_TOP_COUNT=10            # 少数派 获取前 N 条内容，默认 10
# export TMTPOST_TOP_COUNT=10          # 钛媒体 获取前 N 条内容，默认 10
# export SSPAI_FEED_URL="https://sspai.com/feed"           # 少数派 RSS 地址，默认 https://sspai.com/feed
# export TMTPOST_FEED_URL="https://www.tmtpost.com/rss"    # 钛媒体 RSS 地址，默认 https://www.tmtpost.com/rss
# export OPENAI_NEWS_COUNT=10          # OpenAI 获取前 N 条内容，默认 10
# export ANTHROPIC_NEWS_COUNT=10       # Anthropic 获取前 N 条内容，默认 10
# export INFOQ_AI_NEWS_COUNT=10        # InfoQ 获取前 N 条内容，默认 10
